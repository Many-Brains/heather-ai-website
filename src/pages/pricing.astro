---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCard from '../components/PricingCard.astro';
import FaqItem from '../components/FaqItem.astro';
import CtaSection from '../components/CtaSection.astro';
---

<BaseLayout title="Pricing | HeatherAI" description="Simple pricing for AI nutrition coaching. Start free with meal logging.">

  <!-- Header -->
  <section class="pt-32 pb-16 px-6 text-center">
    <h1 class="text-5xl md:text-6xl font-bold tracking-tight">Beta pricing. Start free.</h1>
    <p class="text-lg text-white/45 mt-4">No hidden fees. Upgrade or cancel anytime.</p>
  </section>

  <!-- Beta expectations -->
  <section class="px-6 md:px-12 pb-12">
    <div class="max-w-[640px] mx-auto p-6 border border-accent/20 rounded-xl text-center">
      <h2 class="text-sm font-bold text-white/80 mb-3">HeatherAI is in active beta.</h2>
      <p class="text-[13px] text-white/45 leading-relaxed">
        That means you're getting early access to a product that's improving every week.
        Some features are still being built. You may encounter rough edges. Your feedback
        directly shapes what we build next.
      </p>
      <p class="text-[13px] text-white/45 leading-relaxed mt-3">
        If you want a polished, finished product — this isn't it yet.
        If you want to be part of building something new — <strong class="text-white/75">welcome.</strong>
      </p>
      <p class="text-[13px] text-white/70 leading-relaxed mt-4 pt-4 border-t border-white/[0.06]">
        <strong class="text-accent">Beta pricing is locked for 12 months for every early user.</strong>
        When we open to the public, prices go up. You won't.
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="px-6 md:px-12 pb-28">
    <div class="max-w-[1000px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
      <PricingCard
        tier="Meal Logging"
        price="Free"
        headline="Track your meals with AI."
        features={[
          'Unlimited text meal logging',
          '5 photo meal logs per day',
          'Instant calorie & macro breakdown',
          'Weight, water & caffeine logging',
          'Full meal history',
        ]}
        ctaText="Get Started"
        ctaHref="/coming-soon"
      />

      <PricingCard
        tier="AI Coaching"
        price="$29"
        priceNote="Beta price — locked for 12 months"
        headline="Your personal nutrition coach."
        features={[
          'Everything in Free — plus unlimited photo logging',
          'Personalized daily meal plans',
          'AI coaching adapted to your goals & patterns',
          'Restaurant menu analysis & ordering guidance',
          'Health data trends & AI-powered insights',
          'End-of-day coaching reflections',
          'Proactive check-ins when you go quiet',
          'Personalized video coaching from HeatherAI',
        ]}
        ctaText="Start Coaching"
        ctaHref="/coming-soon"
        highlighted={true}
      />

      <PricingCard
        tier="AI + Human Coach"
        price="$299"
        headline="The full experience."
        features={[
          'Everything in AI Coaching',
          '2 private Zoom sessions/mo',
          'With a registered dietitian',
          'Personalized plan reviews',
          'Priority support',
        ]}
        ctaText="Join Waitlist"
        ctaHref="/coming-soon"
        comingSoon={true}
      />
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-28 px-6 md:px-12 border-t border-white/[0.06]">
    <div class="max-w-[680px] mx-auto">
      <h2 class="text-3xl font-bold tracking-tight text-center mb-12">Frequently asked questions</h2>

      <FaqItem
        question="What makes HeatherAI different from ChatGPT?"
        answer="ChatGPT gives generic nutrition information. HeatherAI is built on real coaching methodology from Heather Bauer, RD — trained on patterns from 5,000+ client transformations. It doesn't just answer questions, it coaches behavior change."
      />
      <FaqItem
        question="Can I cancel anytime?"
        answer="Yes. No contracts, no commitments. You can upgrade, downgrade, or cancel your plan at any time."
      />
      <FaqItem
        question="Will the price go up after beta?"
        answer="Yes — public pricing will be higher. But every beta user's $29/month rate is locked for 12 months from the day you sign up. You're rewarded for being early."
      />
      <FaqItem
        question="Is HeatherAI a replacement for a dietitian?"
        answer="HeatherAI is a coaching tool, not medical advice. It's designed to support your nutrition journey between appointments. For the full experience, the AI + Human Coach plan includes sessions with a registered dietitian."
      />
      <FaqItem
        question="How does meal logging work?"
        answer="Take a photo of your meal or describe it in text. HeatherAI estimates macros and provides feedback based on your personal nutrition plan. Free plan users get unlimited text logging and 5 photo logs per day; paid plans get unlimited photos."
      />
      <FaqItem
        question="What if I'm on a GLP-1 medication?"
        answer="HeatherAI is designed to support anyone on their nutrition journey, including those on GLP-1 medications like Ozempic or Wegovy. The coaching adapts to your specific situation and goals."
      />
    </div>
  </section>

  <!-- Bottom CTA -->
  <CtaSection
    headline={"Not sure? Start free."}
    subline="Try meal logging at no cost. Upgrade when you're ready for coaching."
    showPricingLink={false}
  />
</BaseLayout>
