---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCard from '../components/PricingCard.astro';
import FaqItem from '../components/FaqItem.astro';
import CtaSection from '../components/CtaSection.astro';

// Stripe Payment Link (prod). Its success_url in Stripe is configured to
// redirect to ONBOARDING_TYPEFORM_URL with ?stripe_session_id={CHECKOUT_SESSION_ID} appended.
const STRIPE_CHECKOUT_URL = 'https://buy.stripe.com/28E28qbpa3nQ4hRcQR7N600';
const ONBOARDING_TYPEFORM_URL = 'https://form.typeform.com/to/M8pOWVcQ';

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What makes HeatherAI different from ChatGPT?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "ChatGPT gives accurate nutrition info from textbooks. HeatherAI is built on Heather Bauer's 25-year coaching methodology — her frameworks, her playbooks, her voice. Ask ChatGPT what to eat at a steakhouse, you get a list. Ask HeatherAI, you get the move calibrated to your goals, your patterns, and what you logged at lunch. Methodology, not just knowledge.",
      },
    },
    {
      '@type': 'Question',
      name: 'Can I cancel anytime?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. No contracts, no commitments. You can upgrade, downgrade, or cancel your plan at any time.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does the 7-day free trial work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'You get 7 days of full AI Coaching for free. We collect your card up front so coaching starts immediately. On day 8, your card is charged $39/month and continues monthly. Cancel any time during the trial and you will not be charged.',
      },
    },
    {
      '@type': 'Question',
      name: 'Will the price change later?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'AI Coaching is $39/month after your 7-day free trial. No contracts, no commitments. Cancel any time.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is HeatherAI a replacement for a dietitian?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "HeatherAI is a coaching tool, not medical advice. It's designed to support your nutrition journey between appointments. For the full experience, the AI + Human Coach plan includes sessions with a registered dietitian.",
      },
    },
    {
      '@type': 'Question',
      name: 'How does meal logging work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Take a photo of your meal or describe it in text. HeatherAI estimates macros and provides feedback based on your personal nutrition plan. Free plan users get unlimited text logging and 5 photo logs per day; paid plans get unlimited photos.',
      },
    },
    {
      '@type': 'Question',
      name: "What if I'm on a GLP-1 medication?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'HeatherAI is designed to support anyone on their nutrition journey, including those on GLP-1 medications like Ozempic or Wegovy. The coaching adapts to your specific situation and goals.',
      },
    },
  ],
};
---

<BaseLayout title="Pricing | HeatherAI" description="Simple pricing for AI nutrition coaching. Start free with meal logging.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqLd)}></script>

  <!-- Header -->
  <section class="pt-32 pb-16 px-6 text-center">
    <h1 class="text-5xl md:text-6xl font-bold leading-[1.1] tracking-tight"><em class="not-italic text-accent">Coaching</em>, not tracking.</h1>
    <p class="text-lg text-white/45 mt-4">7-day free trial. Cancel anytime.</p>
  </section>

  <!-- Beta context -->
  <section class="px-6 pb-16 text-center">
    <p class="text-sm text-white/50 max-w-[560px] mx-auto leading-relaxed">
      HeatherAI is in active beta — your feedback directly shapes what we build next.
    </p>
  </section>

  <!-- Pricing Cards -->
  <section class="px-6 md:px-12 pb-28">
    <div class="max-w-[1000px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
      <PricingCard
        tier="Meal Logging"
        price="Free"
        headline="Just the tracker. No coaching."
        features={[
          'Unlimited text meal logging',
          '5 photo meal logs per day',
          'Instant calorie & macro breakdown',
          'Weight, water & caffeine logging',
          'Full meal history',
        ]}
        ctaText="Just track meals"
        ctaHref={ONBOARDING_TYPEFORM_URL}
        confirmId="free-confirm-dialog"
        trackEventName="cta_click"
        trackParams={{ cta_id: 'pricing_free', tier: 'free' }}
      />

      <PricingCard
        tier="AI Coaching"
        price="$39"
        priceNote="7 days free, then $39/mo. Cancel anytime."
        headline="Your personal nutrition coach."
        features={[
          'Everything in Free — plus unlimited photo logging',
          'Personalized daily meal plans',
          'AI coaching adapted to your goals & patterns',
          'Restaurant menu analysis & ordering guidance',
          'Health data trends & AI-powered insights',
          'End-of-day coaching reflections',
          'Proactive check-ins when you go quiet',
          'Personalized video coaching from HeatherAI',
        ]}
        ctaText="Start 7-day free trial"
        ctaHref={STRIPE_CHECKOUT_URL}
        highlighted={true}
        trackEventName="begin_checkout"
        trackParams={{ tier: 'ai_coaching', value: 39, currency: 'USD', cta_location: 'pricing_card' }}
      />

      <PricingCard
        tier="AI + Human Coach"
        price="$299"
        headline="The full experience."
        features={[
          'Everything in AI Coaching',
          '2 private Zoom sessions/mo',
          'With a registered dietitian',
          'Personalized plan reviews',
          'Priority support',
        ]}
        ctaText="Join Waitlist"
        typeformId="Re9H76Ov"
        comingSoon={true}
        trackEventName="cta_click"
        trackParams={{ cta_id: 'pricing_human_coach', tier: 'ai_human' }}
      />
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-28 px-6 md:px-12 border-t border-white/[0.06]">
    <div class="max-w-[680px] mx-auto">
      <h2 class="text-3xl font-bold tracking-tight text-center mb-12">Frequently asked questions</h2>

      <FaqItem
        question="What makes HeatherAI different from ChatGPT?"
        answer="ChatGPT gives accurate nutrition info from textbooks. HeatherAI is built on Heather Bauer's 25-year coaching methodology — her frameworks, her playbooks, her voice. Ask ChatGPT what to eat at a steakhouse, you get a list. Ask HeatherAI, you get the move calibrated to your goals, your patterns, and what you logged at lunch. Methodology, not just knowledge."
      />
      <FaqItem
        question="Can I cancel anytime?"
        answer="Yes. No contracts, no commitments. You can upgrade, downgrade, or cancel your plan at any time."
      />
      <FaqItem
        question="How does the 7-day free trial work?"
        answer="You get 7 days of full AI Coaching for free. We collect your card up front so coaching starts immediately. On day 8, your card is charged $39/month and continues monthly. Cancel any time during the trial and you will not be charged."
      />
      <FaqItem
        question="Will the price change later?"
        answer="AI Coaching is $39/month after your 7-day free trial. No contracts, no commitments. Cancel any time."
      />
      <FaqItem
        question="Is HeatherAI a replacement for a dietitian?"
        answer="HeatherAI is a coaching tool, not medical advice. It's designed to support your nutrition journey between appointments. For the full experience, the AI + Human Coach plan includes sessions with a registered dietitian."
      />
      <FaqItem
        question="How does meal logging work?"
        answer="Take a photo of your meal or describe it in text. HeatherAI estimates macros and provides feedback based on your personal nutrition plan. Free plan users get unlimited text logging and 5 photo logs per day; paid plans get unlimited photos."
      />
      <FaqItem
        question="What if I'm on a GLP-1 medication?"
        answer="HeatherAI is designed to support anyone on their nutrition journey, including those on GLP-1 medications like Ozempic or Wegovy. The coaching adapts to your specific situation and goals."
      />
    </div>
  </section>

  <!-- Bottom CTA -->
  <CtaSection
    headlineHtml={'Want a <em class="not-italic text-accent">nutrition coach</em> in your pocket?'}
    subline="7-day free trial. Cancel anytime."
    ctaText="Start 7-day free trial"
    ctaHref={STRIPE_CHECKOUT_URL}
    showPricingLink={false}
    trackEventName="begin_checkout"
    trackParams={{ tier: 'ai_coaching', value: 39, currency: 'USD', cta_location: 'pricing_bottom' }}
  />

  <!-- Free-tier confirmation dialog -->
  <dialog
    id="free-confirm-dialog"
    class="fixed inset-0 m-auto h-fit max-h-[calc(100vh-2rem)] w-[calc(100%-2rem)] max-w-[480px] p-0 rounded-2xl bg-bg-surface text-white border border-white/[0.08] backdrop:bg-black/70 backdrop:backdrop-blur-sm"
  >
    <div class="relative p-8">
      <button
        type="button"
        id="free-confirm-close"
        aria-label="Close"
        class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center text-white/50 hover:text-white/90 transition-colors"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 3 L13 13 M13 3 L3 13" />
        </svg>
      </button>

      <h3 class="text-xl font-bold tracking-tight mb-4 pr-8">
        Just so we're clear — Free is meal logging only.
      </h3>

      <p class="text-sm text-white/70 leading-relaxed mb-3">
        The Free plan is a tracker: log meals, get macros, see history.
        <strong class="text-white/90">It does not include AI coaching, meal plans, menu analysis, or personalized guidance.</strong>
      </p>

      <p class="text-sm text-white/70 leading-relaxed mb-6">
        If you're looking for a coach, you'll want <strong class="text-white/90">AI Coaching</strong>. Try it free for 7 days, then $39/mo.
      </p>

      <div class="flex flex-col gap-3">
        <button
          type="button"
          id="free-confirm-continue"
          data-track-event="cta_click"
          data-track-params='{"cta_id":"dialog_continue_free","tier":"free"}'
          class="block w-full text-center py-3 px-6 rounded-lg font-semibold text-sm transition-colors bg-white/[0.08] hover:bg-white/[0.12] text-white cursor-pointer"
        >
          I understand — continue to Free
        </button>
        <a
          href={STRIPE_CHECKOUT_URL}
          data-track-event="begin_checkout"
          data-track-params='{"tier":"ai_coaching","value":39,"currency":"USD","cta_location":"dialog_upsell"}'
          class="block w-full text-center py-3 px-6 rounded-lg font-semibold text-sm transition-colors bg-accent hover:bg-accent-hover text-white"
        >
          Try AI Coaching free for 7 days →
        </a>
      </div>
    </div>
  </dialog>

  <script is:inline>
    (function () {
      const dialog = document.getElementById('free-confirm-dialog');
      if (!dialog) return;
      const continueBtn = document.getElementById('free-confirm-continue');
      const closeBtn = document.getElementById('free-confirm-close');
      let pendingHref = null;

      document.querySelectorAll('[data-confirm-id="free-confirm-dialog"]').forEach((el) => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          pendingHref = el.getAttribute('href');
          dialog.showModal();
        });
      });

      continueBtn?.addEventListener('click', () => {
        if (pendingHref) window.location.href = pendingHref;
      });

      closeBtn?.addEventListener('click', () => dialog.close());

      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) dialog.close();
      });
    })();
  </script>

  <!-- Typeform embed script (for waitlist popup) -->
  <script src="//embed.typeform.com/next/embed.js" is:inline></script>

  <!-- view_pricing key event — fires on every /pricing load. Used by GA4 funnel reports. -->
  <script is:inline>
    if (window.trackEvent) {
      window.trackEvent('view_pricing', {});
    }
  </script>
</BaseLayout>
