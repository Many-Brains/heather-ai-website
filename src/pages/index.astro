---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Features from '../components/Features.astro';
import Scenarios from '../components/Scenarios.astro';
import AlwaysOn from '../components/AlwaysOn.astro';
import DataStory from '../components/DataStory.astro';
import Showcase from '../components/Showcase.astro';
import CtaSection from '../components/CtaSection.astro';
import BetaResults from '../components/BetaResults.astro';
import NeutralityCallout from '../components/NeutralityCallout.astro';

const softwareApplicationLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'HeatherAI',
  applicationCategory: 'HealthApplication',
  applicationSubCategory: 'Nutrition coaching',
  operatingSystem: 'Web',
  description:
    'AI-powered personal nutrition coach built on 25 years of methodology from Heather Bauer, RD. Real-time coaching for restaurant orders, GLP-1 nutrition, meal planning, and weight loss.',
  url: 'https://getheatherai.com',
  image: 'https://getheatherai.com/images/heather-bauer.webp',
  provider: {
    '@type': 'Organization',
    name: 'Many Brains, Inc.',
    url: 'https://getheatherai.com',
  },
  offers: [
    {
      '@type': 'Offer',
      name: 'Meal Logging',
      price: '0',
      priceCurrency: 'USD',
      description:
        'Free meal logging, macro estimates, weight and water tracking, full meal history.',
    },
    {
      '@type': 'Offer',
      name: 'AI Coaching',
      price: '39',
      priceCurrency: 'USD',
      description:
        'Full AI nutrition coaching, personalized meal plans, restaurant guidance, health trends, proactive check-ins, weekly video coaching. Includes a 7-day free trial; $39/month after the trial.',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: '39',
        priceCurrency: 'USD',
        billingDuration: 'P1M',
      },
    },
    {
      '@type': 'Offer',
      name: 'AI + Human Coach',
      price: '299',
      priceCurrency: 'USD',
      description:
        'Everything in AI Coaching plus 2 monthly Zoom sessions with a registered dietitian. Currently waitlist-only.',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: '299',
        priceCurrency: 'USD',
        billingDuration: 'P1M',
      },
    },
  ],
};
---

<BaseLayout title="HeatherAI | Your AI Nutrition Coach">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(softwareApplicationLd)}></script>

  <Hero />
  <Scenarios />
  <Stats />
  <Features />
  <BetaResults />
  <NeutralityCallout />
  <DataStory />
  <AlwaysOn />
  <Showcase />
  <CtaSection
    headlineHtml={'Try the coach that <em class="not-italic text-accent">meets you in the moment.</em>'}
    trackEventName="cta_click"
    trackParams={{ cta_id: 'home_bottom_cta', destination: '/pricing' }}
  />
</BaseLayout>
