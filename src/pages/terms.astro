<BaseLayout title="Terms of Service | HeatherAI" description="Terms and conditions for using the HeatherAI nutrition coaching platform.">

  <section class="pt-32 pb-20 px-6 md:px-12">
    <div class="max-w-[720px] mx-auto">

      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 text-center">Terms of Service</h1>
      <p class="text-sm text-white/40 text-center mb-16">Last updated: April 12, 2026</p>

      <div class="space-y-10 text-sm text-white/55 leading-relaxed [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-white [&_h2]:mb-4 [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-white/80 [&_h3]:mb-3 [&_strong]:text-white/75 [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-2 [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:space-y-2">

        <!-- Agreement -->
        <div>
          <h2>Agreement to Terms</h2>
