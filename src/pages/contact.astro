---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | HeatherAI" description="Get in touch with the HeatherAI team — general inquiries, press, partnerships, and support.">

  <!-- Hero -->
  <section class="pt-32 pb-12 px-6 text-center">
    <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-4">Get in touch.</h1>
    <p class="text-lg text-white/45 max-w-[480px] mx-auto">
      Questions, press inquiries, partnerships, or just want to say hello — we'd love to hear from you.
    </p>
  </section>

  <!-- Typeform embed -->
  <section class="px-6 md:px-12 pb-28">
    <div class="max-w-[700px] mx-auto">
      <div data-tf-live="01KP1T04FCTWYV47NWHR0FV9J6"></div>
    </div>
  </section>

  <script src="//embed.typeform.com/next/embed.js" is:inline></script>

</BaseLayout>
