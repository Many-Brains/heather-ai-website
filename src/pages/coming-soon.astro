---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Coming Soon | HeatherAI" description="HeatherAI is in limited beta. Public access coming soon.">

  <section class="min-h-[70vh] flex flex-col items-center justify-center text-center px-6 pt-28 pb-20">

    <!-- Badge -->
    <div class="inline-block px-4 py-1.5 rounded-full border border-accent/30 bg-accent/[0.08] text-[12px] text-accent tracking-[1px] uppercase mb-8">
      Limited Beta
    </div>

    <!-- Headline -->
    <h1 class="text-5xl md:text-7xl font-bold leading-[1.1] max-w-[800px] tracking-tight">
      Launching<br /><em class="not-italic text-accent">soon.</em>
    </h1>

    <!-- Subline -->
    <p class="text-lg md:text-xl text-white/50 max-w-[560px] leading-relaxed mt-8">
      HeatherAI is currently in limited beta with a small group of early users.
      Public access is opening in phases — we're taking our time to get it right.
    </p>

    <p class="text-base text-white/40 max-w-[520px] leading-relaxed mt-6">
      If you'd like to learn more or get on the list, reach out any time.
    </p>

    <!-- Primary CTA -->
    <a
      href="/contact"
      class="mt-10 inline-block px-10 py-4 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl text-base transition-all hover:-translate-y-0.5"
    >
      Get in Touch
    </a>

    <!-- Secondary link back home -->
    <a href="/" class="mt-4 text-[13px] text-white/35 hover:text-white/60 transition-colors">
      &larr; Back to home
    </a>

  </section>

</BaseLayout>
