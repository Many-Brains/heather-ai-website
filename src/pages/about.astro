---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBlock from '../components/CtaBlock.astro';

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Heather Bauer',
  honorificSuffix: 'RD',
  jobTitle: 'Registered Dietitian',
  description:
    'Registered Dietitian, bestselling author, and founder of HeatherAI. Built a 25-year nutrition coaching practice on Park Avenue serving over 5,000 clients across 30,000+ appointments. National television regular and Huffington Post columnist.',
  url: 'https://getheatherai.com/about',
  image: 'https://getheatherai.com/images/heather-bauer.webp',
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'University of Wisconsin',
  },
  hasOccupation: {
    '@type': 'Occupation',
    name: 'Registered Dietitian',
    occupationalCategory: 'Healthcare practitioner',
  },
  worksFor: {
    '@type': 'Organization',
    name: 'HeatherAI',
    url: 'https://getheatherai.com',
  },
  knowsAbout: [
    'Nutrition coaching',
    'Weight loss',
    'Behavior change',
    'GLP-1 nutrition support',
    'Eating psychology',
    'Behavioral nutrition',
    'Meal planning',
    'Pre- and post-natal nutrition',
  ],
  memberOf: [
    {
      '@type': 'Organization',
      name: 'Cooking Light Nutrition Advisory Board',
    },
  ],
  author: [
    {
      '@type': 'Book',
      name: 'The Wall Street Diet',
      datePublished: '2008',
      author: {
        '@type': 'Person',
        name: 'Heather Bauer',
      },
    },
    {
      '@type': 'Book',
      name: 'Bread Is the Devil',
      datePublished: '2012',
      author: {
        '@type': 'Person',
        name: 'Heather Bauer',
      },
    },
  ],
  subjectOf: [
    {
      '@type': 'Book',
      name: 'The Wall Street Diet',
      author: { '@type': 'Person', name: 'Heather Bauer' },
      datePublished: '2008',
    },
    {
      '@type': 'Book',
      name: 'Bread Is the Devil',
      author: { '@type': 'Person', name: 'Heather Bauer' },
      datePublished: '2012',
    },
  ],
};
---

<BaseLayout title="About | HeatherAI" description="Meet Heather Bauer, RD — the bestselling author and registered dietitian whose 25-year coaching practice powers HeatherAI.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(personLd)}></script>

  <!-- ============ HERO ============ -->
  <section class="min-h-[70vh] flex flex-col items-center justify-center text-center px-6 pt-28 pb-20">
    <h1 class="text-5xl md:text-7xl font-bold leading-[1.1] max-w-[800px] tracking-tight">
      The coach behind<br /><em class="not-italic text-accent">the code.</em>
    </h1>
    <p class="text-lg md:text-xl text-white/50 max-w-[560px] leading-relaxed mt-6">
      Heather Bauer, RD, didn't set out to build an AI. She set out to help people change
      how they eat — and spent her career getting really good at it. HeatherAI is what
      happened next.
    </p>

    <!-- Heather's photo -->
    <div class="mt-14 w-full max-w-[540px]">
      <img
        src="/images/heather-bauer.webp"
        alt="Heather Bauer, RD — founder of HeatherAI"
        class="w-full rounded-2xl shadow-[0_30px_60px_-15px_rgba(0,0,0,0.6)] border border-white/[0.06]"
        loading="eager"
      />
      <p class="mt-4 text-[12px] text-white/30 tracking-wide">
        Heather Bauer, RD &middot; Registered Dietitian &middot; Bestselling Author
      </p>
    </div>

    <!-- Press mentions -->
    <div class="mt-10 flex justify-center flex-wrap gap-x-6 gap-y-2 text-[12px] font-bold tracking-[0.08em] text-white/25 uppercase">
      <span>GMA</span><span>Today</span><span>CNN</span><span>The View</span><span>Ellen</span><span>The New York Times</span><span>WSJ</span><span>People</span>
    </div>
  </section>


  <!-- ============ HER STORY ============ -->
  <section class="py-28 px-6 md:px-12 border-t border-white/[0.06]">
    <div class="max-w-[680px] mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-12 text-center">The Story</h2>

      <div class="space-y-10 text-white/55 text-base leading-relaxed">
        <p>
          For 25 years, Heather Bauer ran one of New York's most sought-after private nutrition
          practices: around 5,000 clients, roughly 30,000 appointments, and by her own count
          about a million text messages. Her method never lived in the appointment. It lived in
          the moments between: the client in front of a menu, the 3pm vending machine pull, the
          morning the scale jumped and panic set in. She answered those texts. That is why her
          clients succeeded.
        </p>

        <p>
          It is also why her practice could never grow. Her product was her attention, and there
          is only so much of it. Her concierge 1:1 practice runs $1,500+ per month, which puts
          her out of reach of almost everyone who needs her.
        </p>

        <p>
          HeatherAI exists to break that constraint. Not by replacing Heather Bauer, but by
          packaging what she knows, how she coaches, and when she pushes versus when she
          comforts, and making it available to everyone, instantly, at a price regular people
          can afford.
        </p>
      </div>
    </div>
  </section>


  <!-- ============ THE BOOKS ============ -->
  <section class="py-20 px-6 md:px-12 border-t border-white/[0.06]">
    <div class="max-w-4xl mx-auto">
      <div class="text-[12px] font-bold uppercase tracking-[0.14em] text-accent mb-8">The books</div>
      <div class="grid sm:grid-cols-2 gap-10">
        <a href="https://www.amazon.com/Wall-Street-Diet-Surprisingly-Effortless/dp/1401309194" target="_blank" rel="noopener" class="flex gap-6 items-start group">
          <img src="/images/books/wall-street-diet.webp" alt="The Wall Street Diet book cover" width="120" loading="lazy" class="rounded-lg shadow-xl shrink-0 group-hover:-translate-y-1 transition-transform" />
          <div>
            <h3 class="font-bold group-hover:text-accent transition-colors">The Wall Street Diet</h3>
            <p class="text-sm text-white/50 mt-2 leading-relaxed">The method for busy professionals: lose the weight and keep up with a life that never slows down.</p>
          </div>
        </a>
        <a href="https://www.amazon.com/Bread-Devil-Weight-Loss-Sabotage/dp/1250004195" target="_blank" rel="noopener" class="flex gap-6 items-start group">
          <img src="/images/books/bread-is-the-devil.webp" alt="Bread Is the Devil book cover" width="120" loading="lazy" class="rounded-lg shadow-xl shrink-0 group-hover:-translate-y-1 transition-transform" />
          <div>
            <h3 class="font-bold group-hover:text-accent transition-colors">Bread Is the Devil</h3>
            <p class="text-sm text-white/50 mt-2 leading-relaxed">The diet-saboteur habits book: why we know what to eat and do the opposite, and how to stop.</p>
          </div>
        </a>
      </div>
    </div>
  </section>


  <!-- ============ HER VOICE ============ -->
  <section class="py-28 px-6 md:px-12 border-t border-white/[0.06]">
    <div class="max-w-[800px] mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6 text-center">What it's like to work with Heather.</h2>
      <p class="text-lg text-white/45 text-center mb-16 max-w-[560px] mx-auto">
        Her philosophy is simple: <em class="not-italic text-white/70">"Live your life, not your diet."</em>
        No deprivation. No guilt. No starting over from scratch.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-7 bg-bg-surface border border-white/[0.06] rounded-2xl">
          <p class="text-sm text-white/60 leading-relaxed italic mb-4">
            "She helped me lose over 50 lbs and keep it off 12 months later. I felt so strongly about her plan that I referred her to other family members and she has helped them greatly. She definitely has changed my life for the better."
          </p>
          <div class="text-[11px] text-white/35 uppercase tracking-[2px]">Tom F.</div>
        </div>

        <div class="p-7 bg-bg-surface border border-white/[0.06] rounded-2xl">
          <p class="text-sm text-white/60 leading-relaxed italic mb-4">
            "Over the years Heather has taught me the tricks on how to behave in all situations — work events, dinner parties, cocktail parties, family gatherings. She is my cheerleader and confidant. I have been to other nutritionists but no one has helped me like Heather."
          </p>
          <div class="text-[11px] text-white/35 uppercase tracking-[2px]">Jeffrey L.</div>
        </div>

        <div class="p-7 bg-bg-surface border border-white/[0.06] rounded-2xl">
          <p class="text-sm text-white/60 leading-relaxed italic mb-4">
            "I was in such a dark place and the weight just kept going up. From my first consultation with Heather I knew I made the right decision. I started July 1st and by September 5th I am down 10 lbs. I have learned how to have a balanced diet including my love for ice cream. Did I mention I didn't exercise once?"
          </p>
          <div class="text-[11px] text-white/35 uppercase tracking-[2px]">Melissa M.</div>
        </div>

        <div class="p-7 bg-bg-surface border border-white/[0.06] rounded-2xl">
          <p class="text-sm text-white/60 leading-relaxed italic mb-4">
            "Heather Bauer helped me get back to my original weight after the birth of my 2nd child. It was such a relief after gaining close to 40 lbs. Heather showed me how to eat smart and not deprive myself."
          </p>
          <div class="text-[11px] text-white/35 uppercase tracking-[2px]">Sydney P.</div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============ WHY HEATHERAI ============ -->
  <section class="py-28 px-6 md:px-12 border-t border-white/[0.06]">
    <div class="max-w-[680px] mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6">Why HeatherAI.</h2>

      <div class="space-y-6 text-lg text-white/55 leading-relaxed">
        <p>
          Great coaching never scaled. Heather Bauer could only work with so many people.
          HeatherAI takes everything she's learned across thousands of clients: the same
          methodology, the same frameworks, the same voice, and makes it
          <strong class="text-white/90">available whenever you need it</strong>.
        </p>

        <p class="text-base text-white/45">
          A dedicated human-coach tier is waitlist-only.
        </p>

        <p class="text-base text-white/40">
          Want to understand the data and science behind HeatherAI?
          <a href="/intelligence" class="text-accent hover:underline">See the intelligence →</a>
        </p>
      </div>
    </div>
  </section>


  <!-- ============ CTA ============ -->
  <CtaBlock ctaId="about_bottom_cta" />

</BaseLayout>
