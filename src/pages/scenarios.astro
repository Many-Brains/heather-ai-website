---
import BaseLayout from '../layouts/BaseLayout.astro';

// Curated taste of 6 scenarios, drawn from 20 years of real client SMS coaching (PII-scrubbed).
// Deliberately no overlap with the homepage 3 (menu in hand, 10pm craving) except GLP-1, which
// anchors this page because of its conversion/SEO value.
//
// Format A: Situation → What HeatherAI does (concrete action/output)
// Format B: In-app HeatherAI chat exchange (when real-time conversation IS the value)
// Format C: On your own / With HeatherAI (contrast/delta framing)

const scenarios = [
  {
    format: 'C',
    tag: 'GLP-1 · personalized',
    label: "You're on Ozempic. Eating 40% less. Something feels off.",
    onOwn:
      "You're losing weight but also losing energy, losing muscle, and no one has told you what to actually eat when you can't eat much.",
    withHeather:
      "HeatherAI works <strong class=\"text-white/95\">with</strong> the medication. <em class=\"not-italic text-white/90\">\"Appetite suppressed = every bite matters more, not less. Protein first, every meal: 4-5 oz lean. Skip snacks entirely — you don't need them. 60g protein daily minimum or we lose muscle instead of fat. We're doing this right.\"</em>",
  },
  {
    format: 'A',
    tag: 'Dining out · pre-planning',
    label: "Business dinner tomorrow at a steakhouse you've never been to.",
    action:
      "Text HeatherAI the restaurant the night before. She pulls the menu and sends a pre-dinner note:",
    output:
      "\"I've reviewed Capital Grille — your play is the classic filet (4-5 oz), grilled asparagus, house salad with oil and vinegar on the side. If you want a cocktail, vodka soda with lime — save the wine for tomorrow. Be the talker — you'll eat less without thinking about it. You've got this!!!\"",
  },
  {
    format: 'B',
    tag: 'Social · in the moment',
    label: "It's a wedding. Buffet dinner. Open bar.",
    exchange: [
      { from: 'user', text: '[photo of buffet table]' },
      { from: 'user', text: 'buffet at the reception. help' },
      {
        from: 'ai',
        text: 'Always do a walk-by first!! Assess everything, then build your plate. Protein first (see the carving station?), veggies next, save starch for one thing you really want. Skip the rolls.',
      },
      {
        from: 'ai',
        text: "Don't be first in line — smaller window to eat = smaller portion. Save 2 glasses of champagne for the toasts, water between every drink. You're going to nail this!",
      },
    ],
  },
  {
    format: 'C',
    tag: 'Scale · real time',
    label: 'The scale is up 2 lbs from yesterday.',
    onOwn:
      "You panic. Skip breakfast, cut lunch, spiral by 4pm, and undo the week trying to \"make up for it.\"",
    withHeather:
      "Text HeatherAI the number. <em class=\"not-italic text-white/90\">\"It's sodium from last night's steak plus water. Do not weigh tomorrow — it won't be accurate. Extra liter of water today. You're doing great, keep going!!\"</em>",
  },
  {
    format: 'A',
    tag: 'Recovery · signature tool',
    label: "After a blowout weekend or a stalled week — the Protein Day.",
    action:
      "Heather's signature recovery tool, used on thousands of clients. HeatherAI deploys the same protocol:",
    output:
      "\"Protein day tomorrow — single-day reset. Breakfast: 2-3 hard-boiled eggs OR a 4-egg-white mushroom omelette. Lunch: 4 oz grilled chicken over mixed greens, oil and vinegar. Snack: orange or 2 slices of turkey. Dinner: 4-6 oz grilled fish with steamed spinach. No carbs, crackers, or dairy — just one day. Not too different from your regular day :)\"",
  },
  {
    format: 'C',
    tag: 'Recovery · zero judgment',
    label: "It's been 3 months. Maybe 6. You don't want to explain yourself.",
    onOwn:
      "You don't want to \"start over.\" The thought is exhausting — so you don't open the app.",
    withHeather:
      "You log back in. <em class=\"not-italic text-white/90\">\"Hi!! So glad you're back. No explanations needed. What do you feel like tackling first — a protein day to reset, or just a clean day?\"</em> Zero judgment. No re-education. You pick up exactly where you left off.",
  },
];
---

<BaseLayout
  title="Scenarios | HeatherAI"
  description="A taste of how HeatherAI shows up in the moments that actually derail you — drawn from 20 years of real client coaching."
>

  <!-- ============ HERO ============ -->
  <section class="pt-32 pb-20 px-6 md:px-12 text-center">
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">
      Real moments.<br />
      <em class="not-italic text-accent">Real-time responses.</em>
    </h1>
    <p class="text-lg md:text-xl text-white/50 max-w-[680px] mx-auto leading-relaxed">
      A handful of scenarios drawn from twenty years of real client coaching.
      Names and details have been removed — the coaching moves are Heather's.
    </p>
  </section>

  <!-- ============ SCENARIOS ============ -->
  <section class="pb-20 px-6 md:px-12">
    <div class="max-w-[1000px] mx-auto space-y-6">
      {scenarios.map((s) => (
        <article class="bg-bg-surface border border-white/[0.06] rounded-2xl p-8">
          <div class="text-[10px] text-accent uppercase tracking-[2px] font-semibold mb-3">
            {s.tag}
          </div>
          <h3 class="text-xl md:text-2xl font-bold mb-6 leading-snug">{s.label}</h3>

          {/* Format C: On your own / With HeatherAI */}
          {s.format === 'C' && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="p-5 bg-white/[0.02] border border-white/[0.06] rounded-xl">
                <div class="text-[10px] text-white/40 uppercase tracking-[2px] font-semibold mb-2">
                  On your own
                </div>
                <p class="text-sm text-white/55 leading-relaxed">{s.onOwn}</p>
              </div>
              <div class="p-5 bg-accent/[0.08] border border-accent/25 rounded-xl">
                <div class="text-[10px] text-accent uppercase tracking-[2px] font-semibold mb-2">
                  With HeatherAI
                </div>
                <p class="text-sm text-white/80 leading-relaxed" set:html={s.withHeather}></p>
              </div>
            </div>
          )}

          {/* Format A: Situation → What HeatherAI does */}
          {s.format === 'A' && (
            <div>
              <p class="text-sm text-white/60 leading-relaxed mb-4">{s.action}</p>
              <blockquote class="p-5 bg-accent/[0.08] border-l-4 border-accent rounded-r-xl">
                <p class="text-[15px] text-white/85 leading-relaxed italic">{s.output}</p>
              </blockquote>
            </div>
          )}

          {/* Format B: In-app HeatherAI chat exchange */}
          {s.format === 'B' && (
            <div class="flex justify-center">
              <div style="width: 300px;">
                <div class="rounded-[2.4rem] p-[8px] bg-gradient-to-b from-[#1a1a1a] to-[#0a0a0a] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.6),0_0_0_1px_rgba(255,255,255,0.06)]">
                  <div class="rounded-[2rem] overflow-hidden bg-black flex flex-col" style="aspect-ratio: 9 / 17;">

                    {/* HeatherAI app header */}
                    <div class="flex items-center justify-center pt-4 pb-3 border-b border-white/[0.08] shrink-0">
                      <div class="flex flex-col items-center gap-1">
                        <div class="w-8 h-8 rounded-full bg-[#5856D6] flex items-center justify-center text-[11px] font-bold text-white">H</div>
                        <span class="text-[10px] text-white font-semibold">HeatherAI</span>
                      </div>
                    </div>

                    {/* Messages */}
                    <div class="flex-1 px-3 py-4 flex flex-col justify-center gap-2.5">
                      {s.exchange.map((msg) => (
                        <div
                          class:list={[
                            'max-w-[85%] px-3 py-2 rounded-2xl',
                            msg.from === 'user'
                              ? 'self-end bg-accent/[0.18] border border-accent/30 rounded-br-md'
                              : 'self-start bg-[#262628] rounded-bl-md',
                          ]}
                        >
                          <p class="text-[10px] text-white/95 leading-relaxed">{msg.text}</p>
                        </div>
                      ))}
                    </div>

                    {/* HeatherAI input bar */}
                    <div class="px-3 pb-3 pt-2 shrink-0">
                      <div class="flex items-center gap-2">
                        <div class="flex-1 px-3 py-1.5 rounded-full border border-white/[0.15] text-[9px] text-white/25">
                          Ask HeatherAI…
                        </div>
                      </div>
                    </div>

                  </div>
                </div>
              </div>
            </div>
          )}
        </article>
      ))}
    </div>
  </section>

  <!-- ============ CLOSING CTA ============ -->
  <section class="py-28 px-6 md:px-12 border-t border-white/[0.06]">
    <div class="max-w-[720px] mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6">
        These are a handful of <em class="not-italic text-accent">thousands of moments</em><br class="hidden md:inline" /> HeatherAI coaches you through.
      </h2>
      <p class="text-lg text-white/55 leading-relaxed mb-10">
        The rest, you unlock when you sign up.
      </p>
      <a
        href="/pricing"
        class="inline-block px-10 py-4 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl text-base transition-all hover:-translate-y-0.5"
      >
        Try the Beta
      </a>
    </div>
  </section>

</BaseLayout>
