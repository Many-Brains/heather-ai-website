---
// Homepage teaser: 3 (of eventual 6) in-the-moment scenarios showing what HeatherAI does.
// Format C — "On your own" / "With HeatherAI" — shows the delta, not just the feature.
// Copy is grounded in the SMS coaching corpus (PII-scrubbed composites, not verbatim quotes).

const scenarios = [
  {
    label: "You're at the table. Menu in hand.",
    onOwn:
      "40 items. Everything sounds good. You pick what's familiar, leave overstuffed, and wake up regretting it.",
    withHeather:
      "Snap a photo of the menu — or just text the restaurant name. In 20 seconds: <em class=\"not-italic text-white/90\">\"Filet 4-5 oz, skip the potato, asparagus on the side. One glass of wine or the bread — not both. Enjoy!!!\"</em>",
    tag: "Dining out · real time",
  },
  {
    label: "You're on a GLP-1 and eating 40% less.",
    onOwn:
      "Every food choice matters more, not less. Your doctor didn't explain any of it. You wing it and lose muscle, not fat.",
    withHeather:
      "HeatherAI works <strong class=\"text-white/95\">with</strong> the medication. <em class=\"not-italic text-white/90\">\"Protein first, every meal — 4-5 oz lean. Skip the snacks entirely; appetite is suppressed. 60g protein daily minimum or we lose muscle. We're doing this right.\"</em>",
    tag: "GLP-1 · personalized",
  },
  {
    label: "It's 10pm. You're staring at the pantry.",
    onOwn:
      "Willpower is gone. You cave, and tomorrow starts with shame — which makes the next 10pm harder, not easier.",
    withHeather:
      "Text HeatherAI before you cave. <em class=\"not-italic text-white/90\">\"Wylde One Chill AF Cacao in almond milk — 30 cal, kills the chocolate urge. Brush your teeth right after. You need 48 hrs of no eating after dinner to break this — tomorrow morning we celebrate!\"</em>",
    tag: "After hours · real time",
  },
];
---

<section class="py-28 px-6 md:px-12 border-t border-white/[0.06]">
  <div class="max-w-[1100px] mx-auto">

    <!-- Header -->
    <div class="text-center mb-4">
      <div class="inline-block text-[11px] text-accent uppercase tracking-[3px] font-semibold mb-3">
        What you actually get
      </div>
    </div>
    <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-6 text-center">
      Real moments.<br class="md:hidden" /> <em class="not-italic text-accent">Real-time responses.</em>
    </h2>
    <p class="text-lg text-white/50 text-center max-w-[640px] mx-auto leading-relaxed mb-16">
      Drawn from 20 years of real client coaching — names and details removed.
      HeatherAI shows up in the moments that actually derail you.
    </p>

    <!-- Scenario cards — subgrid aligns tag / title / boxes horizontally across all cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:[grid-template-rows:auto_auto_1fr_1fr]">
      {scenarios.map((s) => (
        <article class="grid gap-3 p-6 bg-bg-surface border border-white/[0.06] rounded-2xl md:[grid-row:span_4] md:[grid-template-rows:subgrid]">
          <div class="text-[10px] text-accent uppercase tracking-[2px] font-semibold">
            {s.tag}
          </div>
          <h3 class="text-lg font-bold leading-snug">{s.label}</h3>

          <!-- On your own -->
          <div class="p-4 bg-white/[0.02] border border-white/[0.06] rounded-xl">
            <div class="text-[10px] text-white/40 uppercase tracking-[2px] font-semibold mb-2">
              On your own
            </div>
            <p class="text-[13px] text-white/55 leading-relaxed">{s.onOwn}</p>
          </div>

          <!-- With HeatherAI -->
          <div class="p-4 bg-accent/[0.08] border border-accent/25 rounded-xl">
            <div class="text-[10px] text-accent uppercase tracking-[2px] font-semibold mb-2">
              With HeatherAI
            </div>
            <p class="text-[13px] text-white/80 leading-relaxed" set:html={s.withHeather}></p>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href="/scenarios" class="text-sm text-accent hover:underline transition-colors font-semibold">
        See more scenarios HeatherAI helps with &rarr;
      </a>
    </div>

  </div>
</section>
