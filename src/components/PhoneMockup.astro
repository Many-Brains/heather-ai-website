---
// PhoneMockup — marketing screenshot inside an iPhone-style frame.
// EXPERIMENTAL — see Hero.astro for the original chat mockup to revert to.
//
// Uses the pre-cropped screenshot (meal-plan-cropped.png) with an HTML
// status bar rendered above it (clock, dynamic island, signal/wifi/battery).
---

<div class="phone-mockup relative mx-auto" style="width: 300px;">
  <!-- Outer bezel / frame -->
  <div
    class="relative rounded-[3rem] p-[12px] bg-gradient-to-b from-[#1a1a1a] to-[#0a0a0a] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.8),0_0_0_1px_rgba(255,255,255,0.06),inset_0_0_0_1px_rgba(255,255,255,0.04)]"
  >
    <!-- Inner screen -->
    <div class="relative rounded-[2.3rem] overflow-hidden bg-[#0a0a0a]">
      <!-- Status bar -->
      <div class="relative flex items-center justify-between px-7 h-[42px] text-white bg-[#0a0a0a]">
        <span class="text-[13px] font-semibold tracking-tight relative z-10">9:41</span>

        <div class="absolute left-1/2 top-[9px] -translate-x-1/2 w-[80px] h-[24px] rounded-full bg-black"></div>

        <div class="flex items-center gap-[5px] relative z-10">
          <svg width="15" height="10" viewBox="0 0 15 10" fill="currentColor" aria-hidden="true">
            <rect x="0" y="6.5" width="2.5" height="3.5" rx="0.5" />
            <rect x="3.5" y="4.5" width="2.5" height="5.5" rx="0.5" />
            <rect x="7" y="2.5" width="2.5" height="7.5" rx="0.5" />
            <rect x="10.5" y="0" width="2.5" height="10" rx="0.5" />
          </svg>
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
            <path d="M1 3.5 A9 9 0 0 1 13 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            <path d="M2.8 5.7 A6 6 0 0 1 11.2 5.7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            <path d="M4.6 7.8 A3 3 0 0 1 9.4 7.8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            <circle cx="7" cy="9.3" r="0.7" fill="currentColor" />
          </svg>
          <svg width="26" height="11" viewBox="0 0 26 11" fill="none" aria-hidden="true">
            <rect x="0.5" y="0.5" width="22" height="10" rx="2.5" stroke="currentColor" stroke-opacity="0.5" />
            <rect x="2" y="2" width="17" height="7" rx="1" fill="currentColor" />
            <rect x="23.5" y="3.5" width="2" height="4" rx="0.7" fill="currentColor" fill-opacity="0.5" />
          </svg>
        </div>
      </div>

      <!-- Screenshot -->
      <img
        src="/experiments/meal-plan-cropped.png"
        alt="HeatherAI daily meal plan on iPhone"
        class="block w-full"
      />
    </div>

    <!-- Side button highlights -->
    <div class="absolute left-[-2px] top-[100px] w-[2px] h-[32px] bg-white/5 rounded-l-sm"></div>
    <div class="absolute left-[-2px] top-[150px] w-[2px] h-[60px] bg-white/5 rounded-l-sm"></div>
    <div class="absolute left-[-2px] top-[220px] w-[2px] h-[60px] bg-white/5 rounded-l-sm"></div>
    <div class="absolute right-[-2px] top-[170px] w-[2px] h-[90px] bg-white/5 rounded-r-sm"></div>
  </div>

  <!-- Ambient glow behind the phone -->
  <div
    class="absolute inset-0 -z-10 blur-[80px] opacity-40 bg-gradient-to-b from-accent/20 via-accent/5 to-transparent rounded-full"
  ></div>
</div>
