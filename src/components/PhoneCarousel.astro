---
// PhoneCarousel — interactive app screenshot carousel in an iPhone frame.
// 5 slides (1 video + 4 screenshots), 5-second auto-advance.
// Features: left/right arrows, click-to-pause, synced captions.
---

<div class="phone-carousel relative mx-auto" style="width: 300px;">

  <!-- Left arrow -->
  <button class="carousel-arrow carousel-prev absolute left-[-48px] top-1/2 -translate-y-1/2 w-9 h-9 flex items-center justify-center rounded-full bg-white/[0.06] hover:bg-white/[0.12] text-white/40 hover:text-white/70 transition-all z-10 cursor-pointer" aria-label="Previous slide">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
  </button>

  <!-- Right arrow -->
  <button class="carousel-arrow carousel-next absolute right-[-48px] top-1/2 -translate-y-1/2 w-9 h-9 flex items-center justify-center rounded-full bg-white/[0.06] hover:bg-white/[0.12] text-white/40 hover:text-white/70 transition-all z-10 cursor-pointer" aria-label="Next slide">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
  </button>

  <!-- Outer bezel / frame (click to pause/resume) -->
  <div
    class="carousel-frame relative rounded-[3rem] p-[12px] bg-gradient-to-b from-[#1a1a1a] to-[#0a0a0a] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.8),0_0_0_1px_rgba(255,255,255,0.06),inset_0_0_0_1px_rgba(255,255,255,0.04)] cursor-pointer"
  >
    <!-- Inner screen -->
    <div class="relative rounded-[2.3rem] overflow-hidden bg-[#0c1724]">
      <!-- Status bar -->
      <div class="relative flex items-center justify-between px-7 h-[42px] text-white bg-[#0a0a0a]">
        <span class="text-[13px] font-semibold tracking-tight relative z-10">9:41</span>
        <div class="absolute left-1/2 top-[9px] -translate-x-1/2 w-[80px] h-[24px] rounded-full bg-black"></div>
        <div class="flex items-center gap-[5px] relative z-10">
          <svg width="15" height="10" viewBox="0 0 15 10" fill="currentColor" aria-hidden="true">
            <rect x="0" y="6.5" width="2.5" height="3.5" rx="0.5" />
            <rect x="3.5" y="4.5" width="2.5" height="5.5" rx="0.5" />
            <rect x="7" y="2.5" width="2.5" height="7.5" rx="0.5" />
            <rect x="10.5" y="0" width="2.5" height="10" rx="0.5" />
          </svg>
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
            <path d="M1 3.5 A9 9 0 0 1 13 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            <path d="M2.8 5.7 A6 6 0 0 1 11.2 5.7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            <path d="M4.6 7.8 A3 3 0 0 1 9.4 7.8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            <circle cx="7" cy="9.3" r="0.7" fill="currentColor" />
          </svg>
          <svg width="26" height="11" viewBox="0 0 26 11" fill="none" aria-hidden="true">
            <rect x="0.5" y="0.5" width="22" height="10" rx="2.5" stroke="currentColor" stroke-opacity="0.5" />
            <rect x="2" y="2" width="17" height="7" rx="1" fill="currentColor" />
            <rect x="23.5" y="3.5" width="2" height="4" rx="0.7" fill="currentColor" fill-opacity="0.5" />
          </svg>
        </div>
      </div>

      <!-- Screenshot carousel area -->
      <div class="relative" style="aspect-ratio: 600 / 1010;">
        <video src="/images/app/weekly-video.mp4" class="carousel-slide" muted playsinline preload="auto" aria-label="Personalized video coaching from HeatherAI"></video>
        <img src="/images/app/meal-planning.webp" alt="HeatherAI daily meal plan" class="carousel-slide" loading="eager" />
        <img src="/images/app/restaurant-guidance.webp" alt="HeatherAI restaurant ordering guidance" class="carousel-slide" loading="lazy" />
        <img src="/images/app/in-moment-coaching.webp" alt="HeatherAI stress eating coaching" class="carousel-slide" loading="lazy" />
        <img src="/images/app/photo-meal-logging.webp" alt="HeatherAI photo meal logging with instant feedback" class="carousel-slide" loading="lazy" />
      </div>

      <!-- Pause indicator (briefly visible when paused) -->
      <div class="carousel-pause-indicator absolute inset-0 flex items-center justify-center pointer-events-none opacity-0 transition-opacity duration-300 z-20">
        <div class="w-14 h-14 rounded-full bg-black/60 flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <rect x="6" y="4" width="4" height="16" rx="1" />
            <rect x="14" y="4" width="4" height="16" rx="1" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Side button highlights -->
    <div class="absolute left-[-2px] top-[120px] w-[2px] h-[32px] bg-white/5 rounded-l-sm"></div>
    <div class="absolute left-[-2px] top-[170px] w-[2px] h-[60px] bg-white/5 rounded-l-sm"></div>
    <div class="absolute left-[-2px] top-[240px] w-[2px] h-[60px] bg-white/5 rounded-l-sm"></div>
    <div class="absolute right-[-2px] top-[200px] w-[2px] h-[90px] bg-white/5 rounded-r-sm"></div>
  </div>

  <!-- Captions + dot indicators -->
  <div class="mt-5">
    <div class="relative h-[40px]">
      <p class="carousel-caption">Personalized video coaching from HeatherAI.</p>
      <p class="carousel-caption">Your personalized meal plan for the day — confirm, swap, or skip.</p>
      <p class="carousel-caption">Real-time restaurant coaching — what to order, what to skip.</p>
      <p class="carousel-caption">Coaching through the hard moments — by name, with a plan.</p>
      <p class="carousel-caption">Snap a photo of your meal — get instant coaching feedback.</p>
    </div>

    <!-- Dot indicators -->
    <div class="flex justify-center gap-2 mt-3">
      <button class="carousel-dot w-2 h-2 rounded-full bg-white/20 transition-all cursor-pointer" aria-label="Slide 1"></button>
      <button class="carousel-dot w-2 h-2 rounded-full bg-white/20 transition-all cursor-pointer" aria-label="Slide 2"></button>
      <button class="carousel-dot w-2 h-2 rounded-full bg-white/20 transition-all cursor-pointer" aria-label="Slide 3"></button>
      <button class="carousel-dot w-2 h-2 rounded-full bg-white/20 transition-all cursor-pointer" aria-label="Slide 4"></button>
      <button class="carousel-dot w-2 h-2 rounded-full bg-white/20 transition-all cursor-pointer" aria-label="Slide 5"></button>
    </div>
  </div>

  <!-- Ambient glow -->
  <div class="absolute inset-0 -z-10 blur-[80px] opacity-40 bg-gradient-to-b from-accent/20 via-accent/5 to-transparent rounded-full"></div>
</div>

<style>
  .carousel-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .carousel-slide.active {
    opacity: 1;
  }

  .carousel-caption {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .carousel-caption.active {
    opacity: 1;
  }

  .carousel-dot.active {
    background-color: rgba(232, 115, 74, 0.8);
    transform: scale(1.25);
  }

  /* Hide arrows on mobile — use dots/tap instead */
  @media (max-width: 420px) {
    .carousel-arrow {
      display: none;
    }
  }
</style>

<script is:inline>
  (function() {
    var slides = document.querySelectorAll('.carousel-slide');
    var captions = document.querySelectorAll('.carousel-caption');
    var dots = document.querySelectorAll('.carousel-dot');
    var frame = document.querySelector('.carousel-frame');
    var prevBtn = document.querySelector('.carousel-prev');
    var nextBtn = document.querySelector('.carousel-next');
    var pauseIndicator = document.querySelector('.carousel-pause-indicator');

    var current = 0;
    var paused = false;
    var timer = null;
    var started = false;       // Has the auto-cycle ever started?
    var videoPlayed = false;   // Has the first video completed one loop?

    function show(index) {
      index = ((index % slides.length) + slides.length) % slides.length;

      slides.forEach(function(s, i) {
        s.classList.toggle('active', i === index);
        if (s.tagName === 'VIDEO') {
          if (i === index) {
            s.muted = true;
            s.currentTime = 0;
            s.play().catch(function() {});
          } else {
            s.pause();
          }
        }
      });

      captions.forEach(function(c, i) {
        c.classList.toggle('active', i === index);
      });

      dots.forEach(function(d, i) {
        d.classList.toggle('active', i === index);
      });

      current = index;
    }

    function next() { show(current + 1); }
    function prev() { show(current - 1); }

    function startTimer() {
      stopTimer();
      started = true;
      timer = setInterval(next, 5000);
    }

    function stopTimer() {
      clearInterval(timer);
      timer = null;
    }

    // Arrow buttons — navigate and reset timer
    prevBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      prev();
      if (!paused) startTimer();
    });

    nextBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      next();
      if (!paused) startTimer();
    });

    // Dot buttons — jump to slide
    dots.forEach(function(dot, i) {
      dot.addEventListener('click', function() {
        show(i);
        if (!paused) startTimer();
      });
    });

    // Click phone frame to pause/resume
    frame.addEventListener('click', function() {
      paused = !paused;
      if (paused) {
        stopTimer();
        pauseIndicator.style.opacity = '1';
        setTimeout(function() { pauseIndicator.style.opacity = '0'; }, 800);
      } else {
        startTimer();
      }
    });

    // Show slide 0 (the video) but DON'T start auto-cycling yet
    show(0);

    // The first slide is a video — when it finishes one loop, start the carousel
    var firstSlide = slides[0];
    if (firstSlide && firstSlide.tagName === 'VIDEO') {
      // Pause the video immediately — wait for scroll visibility
      firstSlide.pause();

      // When the video ends, immediately advance and start cycling
      firstSlide.addEventListener('ended', function() {
        if (!videoPlayed && !paused) {
          videoPlayed = true;
          next();
          startTimer();
        }
      });

      // Use IntersectionObserver to start video only when phone frame is visible
      var observer = new IntersectionObserver(function(entries) {
        var entry = entries[0];
        if (entry.isIntersecting && current === 0 && !videoPlayed) {
          // Phone frame scrolled into view — play the video from the start
          firstSlide.muted = true;
          firstSlide.currentTime = 0;
          firstSlide.play().catch(function() {});
        }
      }, { threshold: 0.4 });

      observer.observe(frame);
    } else {
      // First slide is not a video — just start cycling immediately
      startTimer();
    }
  })();
</script>
