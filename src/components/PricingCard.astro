---
interface Props {
  tier: string;
  price: string;
  period?: string;
  headline: string;
  features: string[];
  ctaText: string;
  ctaHref: string;
  highlighted?: boolean;
}

const { tier, price, period = '/mo', headline, features, ctaText, ctaHref, highlighted = false } = Astro.props;
---

<div class:list={[
  "flex flex-col p-8 rounded-2xl border",
  highlighted
    ? "bg-accent/[0.06] border-accent/30"
    : "bg-bg-surface border-white/[0.06]"
]}>
  <div class="text-[12px] text-white/40 uppercase tracking-[2px] mb-3">{tier}</div>
  <div class="flex items-baseline gap-1 mb-2">
    <span class="text-4xl font-bold">{price}</span>
    {price !== 'Free' && <span class="text-base text-white/40">{period}</span>}
  </div>
  <p class="text-sm text-white/50 mb-6">{headline}</p>

  <ul class="space-y-3 mb-8 flex-1">
    {features.map((feature) => (
      <li class="flex items-start gap-2.5 text-sm text-white/55">
        <span class="text-accent mt-0.5">&#10003;</span>
        <span>{feature}</span>
      </li>
    ))}
  </ul>

  <a
    href={ctaHref}
    class:list={[
      "block text-center py-3 px-6 rounded-lg font-semibold text-sm transition-colors",
      highlighted
        ? "bg-accent hover:bg-accent-hover text-white"
        : "bg-white/[0.08] hover:bg-white/[0.12] text-white"
    ]}
  >
    {ctaText}
  </a>
</div>
