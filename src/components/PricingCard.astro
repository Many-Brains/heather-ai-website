---
interface Props {
  tier: string;
  price: string;
  period?: string;
  priceNote?: string;
  headline: string;
  features: string[];
  ctaText: string;
  ctaHref?: string;
  typeformId?: string;
  highlighted?: boolean;
  comingSoon?: boolean;
}

const { tier, price, period = '/mo', priceNote, headline, features, ctaText, ctaHref, typeformId, highlighted = false, comingSoon = false } = Astro.props;

const ctaClasses = [
  "block w-full text-center py-3 px-6 rounded-lg font-semibold text-sm transition-colors cursor-pointer",
  highlighted
    ? "bg-accent hover:bg-accent-hover text-white"
    : "bg-white/[0.08] hover:bg-white/[0.12] text-white"
];
---

<div class:list={[
  "flex flex-col p-8 rounded-2xl border",
  highlighted
    ? "bg-accent/[0.06] border-accent/30"
    : "bg-bg-surface border-white/[0.06]"
]}>
  <div class="flex items-center gap-3 mb-3">
    <span class="text-[12px] text-white/40 uppercase tracking-[2px]">{tier}</span>
    {comingSoon && (
      <span class="text-[10px] text-accent uppercase tracking-[1px] px-2 py-0.5 border border-accent/30 rounded-full bg-accent/[0.08]">Coming Soon</span>
    )}
  </div>
  <div class="flex items-baseline gap-1 mb-2">
    <span class="text-4xl font-bold">{price}</span>
    {price !== 'Free' && <span class="text-base text-white/40">{period}</span>}
  </div>
  {priceNote && (
    <p class="text-[12px] text-accent font-semibold mb-3">{priceNote}</p>
  )}
  <p class="text-sm text-white/50 mb-6">{headline}</p>

  <ul class="space-y-3 mb-8 flex-1">
    {features.map((feature) => (
      <li class="flex items-start gap-2.5 text-sm text-white/55">
        <span class="text-accent mt-0.5">&#10003;</span>
        <span>{feature}</span>
      </li>
    ))}
  </ul>

  {typeformId ? (
    <button
      type="button"
      data-tf-popup={typeformId}
      data-tf-opacity="100"
      data-tf-size="80"
      data-tf-iframe-props={`title=${tier} Waitlist`}
      data-tf-transitive-search-params
      class:list={ctaClasses}
    >
      {ctaText}
    </button>
  ) : (
    <a
      href={ctaHref}
      class:list={ctaClasses}
    >
      {ctaText}
    </a>
  )}
</div>
