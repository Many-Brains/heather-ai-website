---
interface Props {
  headline?: string;
  subline?: string;
  ctaText?: string;
  ctaHref?: string;
  showPricingLink?: boolean;
}

const {
  headline = 'Start with free meal logging.\nUpgrade when you\'re ready.',
  subline = 'No credit card required. No commitment. Just better nutrition.',
  ctaText = 'Get Started Free',
  ctaHref = '/pricing',
  showPricingLink = true,
} = Astro.props;

const headlineLines = headline.split('\n');
---

<section class="py-36 px-6 md:px-12 border-t border-white/[0.06] text-center">
  <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
    {headlineLines.map((line: string, i: number) => (
      <Fragment>
        {line}{i < headlineLines.length - 1 && <br />}
      </Fragment>
    ))}
  </h2>
  <p class="text-lg text-white/45 mb-10">{subline}</p>
  <a
    href={ctaHref}
    class="inline-block px-10 py-4 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl text-base transition-all hover:-translate-y-0.5"
  >
    {ctaText}
  </a>
  {showPricingLink && (
    <a href="/pricing" class="block mt-4 text-sm text-accent hover:underline transition-colors">
      View pricing &rarr;
    </a>
  )}
</section>
