---
import PhoneCarousel from './PhoneCarousel.astro';
---

<section class="min-h-screen flex flex-col items-center justify-center text-center px-6 pt-28 pb-20">
  <!-- Badge -->
  <div class="inline-block px-4 py-1.5 rounded-full border border-accent/30 bg-accent/[0.08] text-[12px] text-accent tracking-[1px] uppercase mb-8">
    Now in Beta
  </div>

  <!-- Headline -->
  <h1 class="text-5xl md:text-7xl font-bold leading-[1.1] max-w-[900px] tracking-tight">
    Your <em class="not-italic text-accent">always-on</em> nutrition coach.
  </h1>

  <!-- Subline -->
  <p class="text-lg md:text-xl text-white/50 max-w-[680px] leading-relaxed mt-6">
    Meets you without judgment — when the menu is in front of you,
    at 10pm in the kitchen, when the scale moves the wrong way.
    Engineered from 25 years of real coaching with Heather Bauer, RD.
  </p>

  <!-- CTA -->
  <a
    href="/pricing"
    data-track-event="cta_click"
    data-track-params='{"cta_id":"hero_primary","destination":"/pricing"}'
    class="mt-10 inline-block px-10 py-4 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl text-base transition-all hover:-translate-y-0.5"
  >
    Try free for 7 days
  </a>
  <p class="mt-3.5 text-[13px] text-white/35">
    7 days free, then $39/mo. Cancel anytime.
  </p>

  <!-- App screenshot carousel in iPhone frame -->
  <div class="mt-16">
    <PhoneCarousel />
  </div>

</section>
