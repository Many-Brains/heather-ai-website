---
import PhoneCarousel from './PhoneCarousel.astro';
---

<section class="min-h-screen flex flex-col items-center justify-center text-center px-6 pt-28 pb-20">
  <!-- Badge -->
  <div class="inline-block px-4 py-1.5 rounded-full border border-accent/30 bg-accent/[0.08] text-[12px] text-accent tracking-[1px] uppercase mb-8">
    Personalized Nutrition Coaching
  </div>

  <!-- Headline -->
  <h1 class="text-5xl md:text-7xl font-bold leading-[1.1] max-w-[900px] tracking-tight">
    Her methods work.<br /><em class="not-italic text-accent">Now they scale.</em>
  </h1>

  <!-- Subline -->
  <p class="text-lg md:text-xl text-white/50 max-w-[600px] leading-relaxed mt-6">
    Heather Bauer, RD is a bestselling author and one of the nation's most
    sought-after nutritionists. HeatherAI brings 20 years of her
    experience to you — personal, proven, at a fraction of private coaching cost.
  </p>

  <!-- CTA -->
  <a
    href="https://ai.heatherbauer.com"
    class="mt-10 inline-block px-10 py-4 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl text-base transition-all hover:-translate-y-0.5"
  >
    Get Started Free
  </a>
  <a href="/pricing" class="mt-3.5 text-[13px] text-white/35 hover:text-white/60 transition-colors">
    See pricing &rarr;
  </a>

  <!-- App screenshot carousel in iPhone frame -->
  <div class="mt-16">
    <PhoneCarousel />
  </div>

</section>
