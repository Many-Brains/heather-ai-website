---
const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/85 backdrop-blur-xl border-b border-white/[0.06]">
  <div class="flex items-center justify-between px-6 md:px-12 py-5">
    <a href="/" class="flex items-baseline gap-2.5">
      <span class="text-[19px] font-extrabold tracking-tight text-white">Range<span class="inline-block w-[5px] h-[5px] rounded-full bg-accent ml-0.5 align-baseline"></span></span>
      <span class="hidden sm:inline text-[10px] uppercase tracking-[0.16em] text-white/40">by Heather Bauer, RD</span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="/method" class:list={["text-[13px] transition-colors", currentPath === '/method/' || currentPath === '/method' ? 'text-white' : 'text-white/55 hover:text-white']}>Method</a>
      <a href="/glp-1" class:list={["text-[13px] transition-colors", currentPath === '/glp-1/' || currentPath === '/glp-1' ? 'text-white' : 'text-white/55 hover:text-white']}>GLP-1</a>
      <a href="/about" class:list={["text-[13px] transition-colors", currentPath === '/about/' || currentPath === '/about' ? 'text-white' : 'text-white/55 hover:text-white']}>About</a>
      <a href="/pricing" class:list={["text-[13px] transition-colors", currentPath === '/pricing/' || currentPath === '/pricing' ? 'text-white' : 'text-white/55 hover:text-white']}>Pricing</a>
      <a
        href="/pricing"
        data-track-event="cta_click"
        data-track-params='{"cta_id":"nav_cta_desktop","destination":"/pricing"}'
        class="text-[13px] font-semibold px-5 py-2 bg-accent hover:bg-accent-hover text-white rounded-md transition-colors"
      >
        Get Started
      </a>
    </div>

    <!-- Mobile menu toggle (label only — checkbox lives outside flex container for peer to work) -->
    <label for="mobile-menu" class="md:hidden flex flex-col gap-1.5 cursor-pointer p-2">
      <span class="block w-5 h-0.5 bg-white/70"></span>
      <span class="block w-5 h-0.5 bg-white/70"></span>
      <span class="block w-5 h-0.5 bg-white/70"></span>
    </label>
  </div>

  <!-- Checkbox must be a sibling of the dropdown for peer-checked: to work -->
  <input type="checkbox" id="mobile-menu" class="hidden peer" />

  <!-- Mobile dropdown -->
  <div class="hidden peer-checked:flex md:hidden flex-col items-center gap-4 pb-6 border-t border-white/[0.06]">
    <a href="/method" class="text-sm text-white/55 hover:text-white transition-colors pt-4">Method</a>
    <a href="/glp-1" class="text-sm text-white/55 hover:text-white transition-colors">GLP-1</a>
    <a href="/about" class="text-sm text-white/55 hover:text-white transition-colors">About</a>
    <a href="/pricing" class="text-sm text-white/55 hover:text-white transition-colors">Pricing</a>
    <a
      href="/pricing"
      data-track-event="cta_click"
      data-track-params='{"cta_id":"nav_cta_mobile","destination":"/pricing"}'
      class="text-sm font-semibold px-5 py-2 bg-accent hover:bg-accent-hover text-white rounded-md transition-colors"
    >
      Get Started
    </a>
  </div>
</nav>
