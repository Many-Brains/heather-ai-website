---
interface Props {
  title?: string;
}
const { title = 'HeatherAI Ops' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #0d0d0d;
    --surface:  #161616;
    --surface2: #1e1e1e;
    --border:   #2a2a2a;
    --text:     #e8e8e8;
    --muted:    #888;
    --accent:   #E8734A;
    --red:      #e05252;
    --red-bg:   rgba(224,82,82,0.10);
    --orange:   #e0943a;
    --orange-bg:rgba(224,148,58,0.10);
    --green:    #52b788;
    --green-bg: rgba(82,183,136,0.10);
    --blue:     #4a9ede;
    --blue-bg:  rgba(74,158,222,0.10);
    --purple:   #a78bfa;
    --purple-bg:rgba(167,139,250,0.10);
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 14px;
    line-height: 1.6;
    min-height: 100vh;
  }

  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  button {
    cursor: pointer;
    font-family: inherit;
    font-size: 13px;
  }
</style>
