---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI nutrition coaching for GLP-1 users and anyone who struggles to stick to a plan. Built on 25 years of real coaching data from a leading registered dietitian — not generic advice or calorie tracking.' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>

    <!-- Google Analytics (GA4) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-48QXC6BN9L"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-48QXC6BN9L');
    </script>

    <!-- Microsoft Clarity -->
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "waqsrgu98c");
    </script>

    <!-- Custom event helper — used by data-track-event attributes site-wide.
         Add data-track-event="event_name" data-track-params='{"k":"v"}' to any
         clickable element to fire GA4 + Clarity events. Delegated listener
         catches clicks even on dynamically-rendered elements. -->
    <script is:inline>
      window.trackEvent = function(name, params) {
        try { if (window.gtag) window.gtag('event', name, params || {}); } catch (e) {}
        try { if (window.clarity) window.clarity('event', name); } catch (e) {}
      };
      document.addEventListener('click', function(e) {
        var el = e.target && e.target.closest && e.target.closest('[data-track-event]');
        if (!el) return;
        var name = el.getAttribute('data-track-event');
        var raw = el.getAttribute('data-track-params');
        var params = {};
        if (raw) { try { params = JSON.parse(raw); } catch (err) {} }
        window.trackEvent(name, params);
      }, true);
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
