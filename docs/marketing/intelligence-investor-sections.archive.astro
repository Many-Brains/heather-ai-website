<!-- ============ FLYWHEEL — data compounds ============ -->
<section class="py-28 px-6 md:px-12 border-t border-white/[0.06]">
  <div class="max-w-[1100px] mx-auto">
    <div class="text-center mb-14">
      <div class="inline-block text-[11px] text-accent uppercase tracking-[3px] font-semibold mb-3">The Flywheel</div>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight max-w-[900px] mx-auto leading-tight">
        The data <em class="not-italic text-accent">compounds</em>.
      </h2>
    </div>

    <!-- Flywheel diagram: three arcing panels with arrows between -->
    <div class="relative">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8 relative">
        {flywheelStages.map((s, i) => (
          <div class="relative bg-bg-surface border border-white/[0.06] rounded-2xl p-8 text-center">
            <div class="text-[11px] text-accent uppercase tracking-[2px] font-semibold mb-3">{s.label}</div>
            <div class="text-4xl md:text-5xl font-bold tracking-tight mb-3">{s.stat}</div>
            <div class="text-[11px] text-white/40 uppercase tracking-[1.5px] mb-4">{s.years}</div>
            <p class="text-[13px] text-white/55 leading-relaxed">{s.desc}</p>
            {i < 2 && (
              <div class="hidden md:block absolute top-1/2 -right-6 -translate-y-1/2 text-accent/60 text-3xl">→</div>
            )}
          </div>
        ))}
      </div>
    </div>

    <p class="text-center text-[14px] text-white/55 leading-relaxed mt-10 max-w-[640px] mx-auto">
      Every HeatherAI user — with consent — adds new patterns. Historical coaching data is used
      only at the pattern level, never reproduced or attributed.
    </p>
  </div>
</section>
