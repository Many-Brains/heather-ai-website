<!-- ============ MULTI-MODAL — what's in the corpus ============ -->
<section class="py-28 px-6 md:px-12 border-t border-white/[0.06]">
  <div class="max-w-[1100px] mx-auto">
    <div class="text-center mb-16">
      <div class="inline-block text-[11px] text-accent uppercase tracking-[3px] font-semibold mb-3">What's Inside</div>
